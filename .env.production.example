# Gunakan nama domain, misalnya pos.example.com. Untuk uji HTTP melalui IP,
# gunakan APP_DOMAIN=:80 dan APP_ORIGIN=http://ALAMAT_IP_SERVER.
APP_DOMAIN=pos.example.com
APP_ORIGIN=https://pos.example.com

DB_NAME=pos_pakaian
DB_USER=pos_app
DB_PASSWORD=ganti-dengan-password-database-yang-panjang
MYSQL_ROOT_PASSWORD=ganti-dengan-password-root-yang-berbeda

JWT_SECRET=ganti-dengan-random-minimal-32-byte
JWT_REFRESH_SECRET=ganti-dengan-random-lain-minimal-32-byte
